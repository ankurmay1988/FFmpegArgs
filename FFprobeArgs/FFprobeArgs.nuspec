<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<!--https://docs.microsoft.com/en-us/nuget/reference/nuspec-->
	<metadata>
		<id>$id$</id>
		<version>$version$</version>
		<description>Generate arguments for ffprobe executable</description>
		<authors>tqk2811</authors>
		<projectUrl>https://github.com/tqk2811/FFmpegArgs</projectUrl>
		<tags>ffmpeg ffprobe ffprobe-command ffprobe-script</tags>
		<readme>docs\README.MD</readme>
		<license type="expression">MIT</license>
		<repository type="git" url="https://github.com/tqk2811/FFmpegArgs.git"/>
		<dependencies>
			<group targetFramework="netstandard2.0">
				<dependency id="System.Text.Json" version="8.0.5"/>
			</group>
			<group targetFramework="net6.0"/>
			<group targetFramework="net8.0"/>
		</dependencies>
	</metadata>
	<files>
		<file src="..\README.MD" target="docs\" />
		<file src="bin\Release\**\$id$.dll" target="lib\" />
		<file src="bin\Release\**\$id$.xml" target="lib\" />
	</files>
</package>
